# ─── App URLs ─────────────────────────────────────────────────────────────────
# Public URL of the frontend (used by backend for CORS and email links)
APP_URL=http://localhost:3000

# Public URL of the backend API (used by the frontend to make requests)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/top5fantasy

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Secret key for signing JWTs — generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ─── External APIs ────────────────────────────────────────────────────────────
# football-data.org — free tier API key
# Sign up at https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your_key_here

# TheSportsDB — used only for badges and images (non-critical enrichment)
# Free tier available at https://www.thesportsdb.com/api.php
THESPORTSDB_API_KEY=your_key_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Redis — only add this if/when caching is introduced. Leave blank for MVP.
# REDIS_URL=redis://localhost:6379/0

# ─── Environment ──────────────────────────────────────────────────────────────
# Set to "production" when deploying
ENVIRONMENT=development
