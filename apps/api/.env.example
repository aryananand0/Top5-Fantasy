# Copy this file to .env and fill in real values.
# Never commit .env to git.

# --- App ---
APP_NAME=Top5 Fantasy
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Database ---
# Use the psycopg v3 driver prefix for SQLAlchemy 2.x
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/top5fantasy

# --- Security ---
# Generate a strong key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-me-with-a-real-secret

# --- CORS ---
# The exact origin of your frontend (no trailing slash)
FRONTEND_URL=http://localhost:3000

# --- External APIs ---
FOOTBALL_DATA_API_KEY=your-football-data-api-key
THESPORTSDB_API_KEY=                  # optional — leave blank if not using

# --- Optional infrastructure ---
REDIS_URL=                            # not used in MVP; leave blank
